	</owl:Class>
	
	<owl:Class rdf:about="https://onto.mtconnect.org/ontology/construct/FiveAxisMotionCapability">
		<rdfs:subClassOf rdf:resource="https://onto.mtconnect.org/ontology/construct/FourAxisMotionCapability"/>
		<rdfs:label rdf:datatype="&rdf;langString" xml:lang="en">Five Axis Motion Capability</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/FourAxisMotionCapability">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/capabilityOf"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/Machine">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="https://onto.mtconnect.org/ontology/construct/hasComponent"/>
										<owl:onClass>
											<owl:Class>
												<owl:intersectionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/RotaryMotionSystem">
													</rdf:Description>
													<owl:Restriction>
														<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
														<owl:someValuesFrom rdf:resource="https://onto.mtconnect.org/ontology/construct/IndexedRevoluteCapability"/>
													</owl:Restriction>
												</owl:intersectionOf>
											</owl:Class>
										</owl:onClass>
										<owl:minQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">2</owl:minQualifiedCardinality>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
	</owl:Class>
	
	<owl:Class rdf:about="https://onto.mtconnect.org/ontology/construct/Force">
		<rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
		<rdfs:label rdf:datatype="&rdf;langString" xml:lang="en">Force</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="https://onto.mtconnect.org/ontology/construct/FourAxisMotionCapability">
		<rdfs:subClassOf rdf:resource="https://onto.mtconnect.org/ontology/construct/ThreeAxisMotionCapability"/>
		<rdfs:label rdf:datatype="&rdf;langString" xml:lang="en">Four Axis Motion Capability</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/ThreeAxisMotionCapability">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/capabilityOf"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/Machine">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="https://onto.mtconnect.org/ontology/construct/hasComponent"/>
										<owl:someValuesFrom>
											<owl:Class>
												<owl:intersectionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/RotaryMotionSystem">
													</rdf:Description>
													<owl:Restriction>
														<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
														<owl:someValuesFrom rdf:resource="https://onto.mtconnect.org/ontology/construct/IndexedRevoluteCapability"/>
													</owl:Restriction>
												</owl:intersectionOf>
											</owl:Class>
										</owl:someValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
	</owl:Class>
	
	<owl:Class rdf:about="https://onto.mtconnect.org/ontology/construct/HydraulicSystem">
