			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/FiveAxisMotionCapability">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/capabilityOf"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/Machine">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="https://onto.mtconnect.org/ontology/construct/hasComponent"/>
										<owl:onClass>
											<owl:Class>
												<owl:intersectionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="https://onto.mtconnect.org/ontology/construct/RotaryMotionSystem">
													</rdf:Description>
													<owl:Restriction>
														<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
														<owl:someValuesFrom rdf:resource="https://onto.mtconnect.org/ontology/construct/IndexedRevoluteCapability"/>
													</owl:Restriction>
												</owl:intersectionOf>
											</owl:Class>
										</owl:onClass>
										<owl:minQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">3</owl:minQualifiedCardinality>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
	</owl:Class>
	
